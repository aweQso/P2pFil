<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:P2PFil.Controls"
             x:Class="P2PFil.MainPage"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#020617" Offset="0.0" />
            <GradientStop Color="#090D16" Offset="0.6" />
            <GradientStop Color="#020617" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <Border x:Name="AnimatedContent" Opacity="0" Margin="20,40,20,100" Padding="20" Background="#090D16" Stroke="#1E293B" StrokeThickness="1.5" VerticalOptions="Fill">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto, Auto, Auto, Auto, *">
                <!-- Row 0: Profil Başlığı -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" VerticalOptions="Center">
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                        <Label Text="P2P Transfer" FontSize="30" FontAttributes="Bold" TextColor="White" />
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Ellipse Fill="#10B981" WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                            <Label Text="Güvenli ağdasın" FontSize="13" TextColor="#94A3B8" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Border Grid.Column="1" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 25" StrokeThickness="2" Stroke="#10B981" Background="#111827">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProfileAvatarTapped" />
                        </Border.GestureRecognizers>
                        <Image x:Name="MyProfileImageMain" Aspect="AspectFill" />
                    </Border>
                </Grid>

                <!-- Row 1: Bilgi Kartı -->
                <Border Grid.Row="1" Background="#111827" Stroke="#1E293B" StrokeThickness="1" Padding="15,10" Margin="0,15,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Label Text="Profil üzerinden belirlenen isimle ağa bağlanılıyor." FontSize="12" TextColor="#94A3B8" HorizontalOptions="Center"/>
                </Border>

                <!-- Row 2: Arama Kutusu -->
                <Border Grid.Row="2" Background="#111827" Stroke="#1E293B" StrokeThickness="1" Padding="12,0" Margin="0,15,0,0" HeightRequest="46">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Label Grid.Column="0" Text="🔍" FontSize="15" VerticalOptions="Center" Margin="0,0,8,0" />
                        <Entry Grid.Column="1" x:Name="SearchEntry" Placeholder="Cihaz ara..." PlaceholderColor="#64748B" TextColor="White"
                               BackgroundColor="Transparent" VerticalOptions="Center" TextChanged="OnSearchTextChanged" />
                        <Button Grid.Column="2" x:Name="ClearSearchButton" Text="✕" IsVisible="False" BackgroundColor="Transparent"
                                TextColor="#64748B" FontSize="14" WidthRequest="30" Padding="0" Clicked="OnClearSearchClicked" />
                    </Grid>
                </Border>

                <!-- Row 3: Başlık + Sayaç -->
                <Grid Grid.Row="3" ColumnDefinitions="*, Auto" Margin="0,18,0,0">
                    <Label Grid.Column="0" Text="Bulunan Cihazlar" FontAttributes="Bold" FontSize="14" TextColor="#F8FAFC" VerticalOptions="Center" />
                    <Border Grid.Column="1" Background="#111827" Stroke="#1E293B" StrokeThickness="1" Padding="10,3">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Label x:Name="PeerCountLabel" Text="0" FontSize="12" FontAttributes="Bold" TextColor="#10B981" />
                    </Border>
                </Grid>

                <!-- Row 4: Peers Listesi -->
                <RefreshView Grid.Row="4" x:Name="PeersRefreshView" Refreshing="OnPeersRefreshing" Margin="0,10,0,0">
                    <CollectionView x:Name="PeersList" SelectionMode="Single" SelectionChanged="OnPeerSelected">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,40,0,0">
                                <Label Text="📡" FontSize="34" HorizontalOptions="Center" Opacity="0.6" />
                                <Label Text="Ağ dinleniyor..." TextColor="#64748B" HorizontalOptions="Center" FontAttributes="Bold" />
                                <Label Text="Aynı ağdaki cihazlar burada görünecek" TextColor="#475569" FontSize="12" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Mesaj" BackgroundColor="#6366F1" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenChatCommand}" CommandParameter="{Binding .}" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Border Margin="0,6" Padding="15" Background="#111827" Stroke="#1E293B" StrokeThickness="1.5">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                                            <Grid Grid.Column="0">
                                                <Border StrokeShape="RoundRectangle 20"
                                                        Stroke="#334155"
                                                        StrokeThickness="1"
                                                        WidthRequest="40"
                                                        HeightRequest="40"
                                                        Background="#090D16">
                                                    <Image Source="{Binding ProfileImagePath}" Aspect="AspectFill" />
                                                </Border>
                                            </Grid>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0,0,0">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#E2E8F0" />
                                            </VerticalStackLayout>
                                            <Path Grid.Column="2" Fill="#10B981" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>
        </Border>

        <controls:CustomTabBar x:Name="MyCustomTabBar" />
    </Grid>
</ContentPage>