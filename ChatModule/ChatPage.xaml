<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:P2PFil.ChatModule"
             xmlns:helpers="clr-namespace:P2PFil.Helpers"
             x:Class="P2PFil.ChatModule.ChatPage"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:AlignmentConverter x:Key="AlignmentConverter" />
            <helpers:MessageColorConverter x:Key="MessageColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Senin yazdığın harika gradient arka plan -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0.0" />
            <GradientStop Color="#1E293B" Offset="0.5" />
            <GradientStop Color="#0F172A" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto, *, Auto" Padding="15,40,15,20">

        <!-- Üst Başlık, Geri Butonu ve Profil Resmi -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, *" Padding="5,0,0,10" VerticalOptions="Center">
            <!-- Geri Butonu (C#'daki OnBackClicked metodunu tetikler) -->
            <Button Grid.Column="0" Text="◀" Clicked="OnBackClicked" BackgroundColor="Transparent" TextColor="White" FontSize="18" WidthRequest="45" VerticalOptions="Center" Padding="0"/>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Border WidthRequest="45" HeightRequest="45" StrokeShape="RoundRectangle 22" Stroke="#30FFFFFF" Background="#15FFFFFF" VerticalOptions="Center">
                    <Image x:Name="MyProfileImageChat" Source="{Binding TargetProfileImagePath}" Aspect="AspectFill" />
                </Border>
                <Ellipse x:Name="OnlineDot" Fill="#10B981" WidthRequest="12" HeightRequest="12" Stroke="#0F172A" StrokeThickness="2"
                         HorizontalOptions="End" VerticalOptions="End" Margin="0,0,-2,-2" />
            </Grid>

            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Margin="12,0,0,0" Spacing="1">
                <Label Text="{Binding TargetName}" FontSize="18" FontAttributes="Bold" TextColor="White" LineBreakMode="TailTruncation" />
                <Label x:Name="StatusLabel" Text="Çevrimiçi" FontSize="11" TextColor="#10B981" />
            </VerticalStackLayout>
        </Grid>

        <!-- Mesaj Listesi -->
        <Grid Grid.Row="1">
            <CollectionView x:Name="MessagesListView" Margin="0,10" Scrolled="OnMessagesScrolled">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="💬" FontSize="36" HorizontalOptions="Center" Opacity="0.6" />
                        <Label Text="Henüz mesaj yok" TextColor="#94A3B8" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="İlk mesajı göndererek sohbete başla" TextColor="#64748B" FontSize="12" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:ChatMessage">
                        <Grid Padding="0,5">
                            <!-- Gün Ayırıcı Etiketi (o mesaj günün ilk mesajıysa görünür) -->
                            <Label Text="{Binding DateSeparatorText}" FontSize="11" TextColor="#94A3B8" FontAttributes="Bold"
                                   HorizontalOptions="Center" Margin="0,10,0,14" IsVisible="{Binding ShowDateSeparator}"
                                   BackgroundColor="#15FFFFFF" Padding="12,4">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding ShowDateSeparator}" Value="False">
                                        <Setter Property="HeightRequest" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Border BackgroundColor="{Binding IsMe, Converter={StaticResource MessageColorConverter}}" 
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16"
                                    HorizontalOptions="{Binding IsMe, Converter={StaticResource AlignmentConverter}}"
                                    Padding="15,12"
                                    MaximumWidthRequest="280">

                                <VerticalStackLayout Spacing="5">

                                    <!-- 1. METİN MESAJI -->
                                    <Label Text="{Binding Content}" FontSize="15" TextColor="White">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding MessageType}" Value="Text">
                                                <Setter Property="IsVisible" Value="True"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding MessageType}" Value="Image">
                                                <Setter Property="IsVisible" Value="False"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding MessageType}" Value="Video">
                                                <Setter Property="IsVisible" Value="False"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- 2. FOTOĞRAF MESAJI -->
                                    <Grid>
                                        <Image Source="{Binding LocalMediaPath}" HeightRequest="180" Aspect="AspectFill">
                                            <Image.Clip>
                                                <RoundRectangleGeometry CornerRadius="12" Rect="0,0,280,180" />
                                            </Image.Clip>
                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image" Binding="{Binding MessageType}" Value="Text">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Image" Binding="{Binding MessageType}" Value="Image">
                                                    <Setter Property="IsVisible" Value="True"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Image" Binding="{Binding MessageType}" Value="Video">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Image.Triggers>
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnMediaTapped" CommandParameter="{Binding LocalMediaPath}"/>
                                            </Image.GestureRecognizers>
                                        </Image>
                                    </Grid>

                                    <!-- 3. VİDEO MESAJI -->
                                    <Frame BackgroundColor="#33000000" CornerRadius="10" Padding="10" BorderColor="Transparent">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame" Binding="{Binding MessageType}" Value="Text">
                                                <Setter Property="IsVisible" Value="False"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Frame" Binding="{Binding MessageType}" Value="Image">
                                                <Setter Property="IsVisible" Value="False"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Frame" Binding="{Binding MessageType}" Value="Video">
                                                <Setter Property="IsVisible" Value="True"/>
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnMediaTapped" CommandParameter="{Binding LocalMediaPath}"/>
                                        </Frame.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="🎬" FontSize="20" VerticalOptions="Center"/>
                                            <Label Text="{Binding Content}" TextColor="LightBlue" TextDecorations="Underline" VerticalOptions="Center" LineBreakMode="TailTruncation" MaximumWidthRequest="150"/>
                                        </HorizontalStackLayout>
                                    </Frame>

                                    <!-- SAAT + DURUM -->
                                    <HorizontalStackLayout HorizontalOptions="End" Spacing="4">
                                        <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm}'}" FontSize="10" TextColor="#B3FFFFFF"/>
                                        <Label Text="{Binding StatusIcon}" FontSize="10" TextColor="#B3FFFFFF" IsVisible="{Binding IsMe}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Yeni mesaj geldiğinde ve kullanıcı yukarıdaysa gösterilecek "aşağı in" rozeti -->
            <Border x:Name="NewMessageBadge" IsVisible="False" HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,10"
                    Background="#6366F1" Padding="14,8" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewMessageBadgeTapped" />
                </Border.GestureRecognizers>
                <Label Text="↓ Yeni mesaj" TextColor="White" FontSize="12" FontAttributes="Bold" />
            </Border>
        </Grid>

        <!-- Mesaj Giriş Alanı -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto" HeightRequest="50" ColumnSpacing="10" VerticalOptions="End" Margin="0,10,0,0">

            <Button Grid.Column="0" x:Name="AttachButton" Text="📎" Clicked="OnAttachClicked" WidthRequest="50" BackgroundColor="#30FFFFFF" TextColor="White" FontSize="20" CornerRadius="12" Padding="0"/>

            <Border Grid.Column="1" BackgroundColor="#15FFFFFF" StrokeShape="RoundRectangle 12" StrokeThickness="0" VerticalOptions="Fill">
                <Entry x:Name="MessageEntry" 
                       Placeholder="Bir mesaj yaz..." 
                       PlaceholderColor="#94A3B8" 
                       TextColor="White" 
                       VerticalOptions="Center"
                       Margin="10,0"
                       ReturnType="Send"
                       Completed="OnSendClicked"/>
            </Border>

            <Button Grid.Column="2" x:Name="SendButton" Text="Gönder" Clicked="OnSendClicked" BackgroundColor="#6366F1" TextColor="White" CornerRadius="12" WidthRequest="80" FontAttributes="Bold"/>
        </Grid>
    </Grid>
</ContentPage>
