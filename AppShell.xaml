<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="P2PFil.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:P2PFil">

    <!-- TabBar'ı tamamen sildik, sadece sayfaları tanımlıyoruz -->
    <ShellContent Route="MainPage" ContentTemplate="{DataTemplate local:MainPage}" />
    <ShellContent Route="FilesPage" ContentTemplate="{DataTemplate local:FilesPage}" />
    <ShellContent Route="ProfilePage" ContentTemplate="{DataTemplate local:ProfilePage}" />

</Shell>