<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:P2PFil.Helpers"
             xmlns:controls="clr-namespace:P2PFil.Controls"
             x:Class="P2PFil.FilesPage"
             Shell.TabBarIsVisible="False"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:InvertedBoolConverter x:Key="InvertedBool" />
        <helpers:FileTypeIconConverter x:Key="FileTypeIcon" />
    </ContentPage.Resources>

    <!-- Derin Pitch-Black Arka Plan -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#020617" Offset="0.0" />
            <GradientStop Color="#090D16" Offset="0.6" />
            <GradientStop Color="#020617" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <Grid x:Name="AnimatedContent" Opacity="1" TranslationX="0" Padding="20,40,20,100" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1.1*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <!-- Scan Bar İçin -->
                <RowDefinition Height="1.4*" />
            </Grid.RowDefinitions>

            <!-- Üst Butonlar -->
            <Grid Grid.Row="0" ColumnDefinitions="*, *" ColumnSpacing="15">
                <Button Grid.Column="0" Text="Dosya Paylaş" Clicked="OnSelectFileClicked" BackgroundColor="#10B981" TextColor="White" CornerRadius="12" HeightRequest="48" FontAttributes="Bold" />
                <Button Grid.Column="1" Text="Ağı Tara" Clicked="OnRefreshClicked" BackgroundColor="#1E293B" TextColor="#E2E8F0" BorderColor="#334155" BorderWidth="1" CornerRadius="12" HeightRequest="48" FontAttributes="Bold" />
            </Grid>

            <!-- Arama Kutusu -->
            <Border Grid.Row="1" Background="#111827" Stroke="#1E293B" StrokeThickness="1" Padding="12,0" HeightRequest="44" Margin="0,4,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Label Grid.Column="0" Text="🔍" FontSize="14" VerticalOptions="Center" Margin="0,0,8,0" />
                    <Entry Grid.Column="1" x:Name="FileSearchEntry" Placeholder="Dosya veya kişi ara..." PlaceholderColor="#64748B" TextColor="White"
                           BackgroundColor="Transparent" VerticalOptions="Center" TextChanged="OnFileSearchTextChanged" />
                    <Button Grid.Column="2" x:Name="ClearFileSearchButton" Text="✕" IsVisible="False" BackgroundColor="Transparent"
                            TextColor="#64748B" FontSize="13" WidthRequest="28" Padding="0" Clicked="OnClearFileSearchClicked" />
                </Grid>
            </Border>

            <Label Grid.Row="2" Text="Benim Paylaşımlarım" FontAttributes="Bold" FontSize="15" TextColor="#94A3B8" Margin="5,10,0,0"/>

            <!-- Benim Dosyalarım Listesi -->
            <CollectionView Grid.Row="3" x:Name="MyFilesList">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Margin="0,20">
                        <Label Text="📁" FontSize="28" HorizontalOptions="Center" Opacity="0.6" />
                        <Label Text="Henüz dosya paylaşmadın" TextColor="#64748B" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Kaldır" BackgroundColor="#EF4444" Invoked="OnDeleteFileSwiped" CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Background="#090D16" Stroke="#1E293B" StrokeThickness="1.5" Margin="0,5" Padding="14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="12">
                                    <Border Grid.RowSpan="3" Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" StrokeThickness="1.5" Stroke="#334155" Background="#111827" VerticalOptions="Center">
                                        <Label Text="{Binding FileName, Converter={StaticResource FileTypeIcon}}" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding FileName}" FontAttributes="Bold" TextColor="#F8FAFC" LineBreakMode="WordWrap" FontSize="14"/>
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding FileSize, StringFormat='Boyut: {0}'}" FontSize="11" TextColor="#64748B" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding UploadDate, StringFormat='Tarih: {0:dd.MM.yyyy HH:mm}'}" FontSize="10" TextColor="#475569" FontAttributes="Italic" />

                                    <Button Grid.RowSpan="3" Grid.Column="2" Text="Kaldır" Clicked="OnDeleteFileClicked" CommandParameter="{Binding .}" 
                                            BackgroundColor="#26EF4444" TextColor="#FCA5A5" BorderColor="#EF4444" BorderWidth="1"
                                            CornerRadius="8" HeightRequest="32" WidthRequest="65" FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Grid.Row="4" Text="Ağda Aktif Dosyalar" FontAttributes="Bold" FontSize="15" TextColor="#94A3B8" Margin="5,10,0,0"/>

            <!-- Tür Filtre Çipleri -->
            <ScrollView Grid.Row="5" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,4,0,0">
                <HorizontalStackLayout x:Name="FilterChipsLayout" Spacing="8">
                    <!-- Chip'ler code-behind'da doldurulur: Tümü / Resim / Video / Belge / Diğer -->
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Tarama Barı -->
            <ProgressBar Grid.Row="6" x:Name="ScanProgressBar" Progress="0" ProgressColor="#10B981" HeightRequest="4" BackgroundColor="Transparent" IsVisible="False" Margin="0,4,0,4"/>

            <!-- Ağdaki Dosyalar Listesi -->
            <CollectionView Grid.Row="7" x:Name="NetworkFilesCollection">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Margin="0,20">
                        <Label Text="🌐" FontSize="28" HorizontalOptions="Center" Opacity="0.6" />
                        <Label Text="Ağda paylaşılan dosya bulunamadı" TextColor="#64748B" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold" />
                        <Label Text="'Ağı Tara' ile yeniden dene" TextColor="#475569" FontSize="11" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#090D16" Stroke="#1E293B" StrokeThickness="1.5" Margin="0,6" Padding="16">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="12">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                    <Border Grid.Column="0" WidthRequest="46" HeightRequest="46" StrokeShape="RoundRectangle 23" StrokeThickness="1.5" Stroke="#10B981" Background="#111827" VerticalOptions="Center">
                                        <Image Source="{Binding OwnerProfileImagePath}" Aspect="AspectFill" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding FileName}" FontAttributes="Bold" FontSize="14" TextColor="#F8FAFC" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding OwnerName, StringFormat='Kimden: {0}'}" FontSize="12" TextColor="#6366F1" FontAttributes="Bold"/>
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding FileSize}" FontSize="11" TextColor="#64748B" />
                                            <Label Text="•" FontSize="11" TextColor="#475569" />
                                            <Label Text="{Binding UploadDate, StringFormat='{0:dd.MM.yyyy HH:mm}'}" FontSize="11" TextColor="#64748B" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <Button Grid.Column="2" Text="{Binding ActionButtonText}" Clicked="OnStartDownloadClicked" CommandParameter="{Binding .}" 
                                            IsVisible="{Binding CanStartOrResume}"
                                            BackgroundColor="#10B981" TextColor="White" CornerRadius="8" HeightRequest="35" WidthRequest="80" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                                </Grid>

                                <!-- İndirme Kontrolleri -->
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" IsVisible="{Binding IsActiveOrRetrying}" Margin="0,4,0,0">
                                    <ProgressBar Grid.Row="0" Grid.ColumnSpan="2" Progress="{Binding Progress}" ProgressColor="#6366F1" HeightRequest="4" Margin="0,0,0,12"/>
                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="10" VerticalOptions="Center">
                                        <Label Text="{Binding SpeedText}" FontSize="11" TextColor="#10B981" FontAttributes="Bold"/>
                                        <Label Text="•" FontSize="11" TextColor="#475569" />
                                        <Label Text="{Binding EtaText}" FontSize="11" TextColor="#94A3B8"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                        <Button Text="İptal" Clicked="OnCancelClicked" CommandParameter="{Binding .}" HeightRequest="28" Padding="10,0" BackgroundColor="#1DEF4444" TextColor="#FCA5A5" BorderColor="#EF4444" BorderWidth="1" CornerRadius="6" FontSize="11" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        <controls:CustomTabBar x:Name="MyCustomTabBar" />
    </Grid>
</ContentPage>
